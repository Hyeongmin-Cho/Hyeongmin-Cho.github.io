---
layout: none
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign all_items = site.pages | concat: site.posts %}
  {% for item in all_items %}
    {% if item.url != nil and item.sitemap_exclude != true %}
      <url>
        <loc>{{ item.url | absolute_url }}</loc>
        {% if item.last_modified_at %}
          <lastmod>{{ item.last_modified_at | date_to_xmlschema }}</lastmod>
        {% else %}
          <lastmod>
            {% if item.date %}
              {{ item.date | date_to_xmlschema }}
            {% else %}
              {{ site.time | date_to_xmlschema }}
            {% endif %}
          </lastmod>
        {% endif %}
        <changefreq>weekly</changefreq>
        <priority>{% if item.url == "/" %}1.0{% else %}0.7{% endif %}</priority>
      </url>
    {% endif %}
  {% endfor %}
</urlset>
